{
  "name": "marathonstream-electron",
  "version": "1.0.0",
  "description": "Twitch sub-marathon countdown timer - Electron desktop app",
  "main": "main.js",
  "author": "Yanis",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win"
  },
  "build": {
    "appId": "com.yanis.marathonstream",
    "productName": "MarathonStream",
    "files": [
      "main.js",
      "ui/**/*",
      "build/icon.ico"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "runAfterFinish": true,
      "deleteAppDataOnUninstall": false
    }
  },
  "devDependencies": {
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3"
  }
}
